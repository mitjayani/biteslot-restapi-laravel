{
    "name": "biteslot/restapi-laravel",
    "description": "Laravel integration for the biteslot POS connector. Maps your storefront products to POS menu items, forwards web orders to the POS, and receives status webhooks. Built on biteslot/restapi-sdk.",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://biteslot.com",
    "require": {
        "php": ">=7.4",
        "biteslot/restapi-sdk": "^1.0",
        "illuminate/support": "^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.5 || ^10.0",
        "orchestra/testbench": "^5.0 || ^6.0 || ^7.0 || ^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "Biteslot\\Connector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Biteslot\\Connector\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Biteslot\\Connector\\ConnectorServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/mitjayani/biteslot-restapi-sdk.git"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
